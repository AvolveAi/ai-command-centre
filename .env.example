# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it's in .gitignore for a reason.

# Notion — notion.so/my-integrations
NOTION_API_KEY=your-notion-key-here

# Slack — api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_TEAM_ID=your-team-id-here

# GitHub — github.com → Settings → Developer Settings → Personal Access Tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token-here

# Brave Search — brave.com/search/api
BRAVE_API_KEY=your-brave-key-here

# Firecrawl — firecrawl.dev
FIRECRAWL_API_KEY=fc-your-key-here
