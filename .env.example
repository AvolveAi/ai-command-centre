# API Key Reference
# These are the environment variables needed for your MCPs.
#
# DO NOT put your real keys in this file.
# Add them to your shell profile instead (~/.zshrc or ~/.bash_profile):
#
#   export NOTION_API_KEY="your-key-here"
#   export SLACK_BOT_TOKEN="your-token-here"
#   export SLACK_TEAM_ID="your-team-id-here"
#   export GITHUB_PERSONAL_ACCESS_TOKEN="your-token-here"
#   export BRAVE_API_KEY="your-key-here"
#   export FIRECRAWL_API_KEY="your-key-here"
#
# Then run: source ~/.zshrc
# Claude Code will pick them up automatically.

# Where to get each key:
# NOTION_API_KEY              — notion.so/my-integrations
# SLACK_BOT_TOKEN             — api.slack.com/apps
# SLACK_TEAM_ID               — api.slack.com/apps (under Basic Information)
# GITHUB_PERSONAL_ACCESS_TOKEN — github.com → Settings → Developer Settings → Personal Access Tokens
# BRAVE_API_KEY               — brave.com/search/api
# FIRECRAWL_API_KEY           — firecrawl.dev
